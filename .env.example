# ─── PuntHub Beta — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in the values for each gateway you want to use.
# Vite exposes only variables prefixed with VITE_ to the browser bundle.
#
# GitHub Secrets setup (CI / GitHub Pages deploy)
# ────────────────────────────────────────────────
# All VITE_* variables below must also be added as GitHub Repository Secrets so
# the GitHub Actions build job can inject them at build time.
#
# How to add secrets in GitHub:
#   1. Go to your repository on GitHub
#   2. Settings → Secrets and variables → Actions → New repository secret
#   3. Add each VITE_* variable as a secret with the same name
#   4. The deploy.yml workflow reads them via ${{ secrets.VITE_... }}
#
# ⚠️  Never commit your actual .env file or expose secrets in pull-request logs.

# ── Polymarket Gamma API ───────────────────────────────────────────────────────
# No API key required — Polymarket Gamma API is public.
# The app automatically fetches live prediction markets on start-up.

# ── Polygon RPC ────────────────────────────────────────────────────────────────
# Any Polygon mainnet RPC endpoint works (Alchemy, Infura, or the public RPC).
# Required for Magic SDK and Polymarket trading.
# Public fallback: https://polygon-rpc.com  (rate-limited; use your own for production)
VITE_POLYGON_RPC_URL=https://polygon-rpc.com

# ── Magic (Passwordless Email OTP + Embedded Wallet) ──────────────────────────
# 1. Sign up at https://magic.link and create a new app
# 2. In the Magic Dashboard, enable "Embedded Wallet" and set the network to Polygon
# 3. Copy your Publishable API Key (starts with pk_live_ or pk_test_)
# Docs: https://docs.magic.link/home/integrations/embedded-wallets/polymarket
VITE_MAGIC_PUBLISHABLE_KEY=

# ── Polymarket Builder Program ─────────────────────────────────────────────────
# Required for gasless trading and builder order attribution via the CLOB Client
# and Builder Relayer Client.
#
# 1. Visit https://polymarket.com/settings?tab=builder to apply for the Builder Program
# 2. Once approved, obtain your API Key and Passphrase from the same settings page
#
# IMPORTANT — Builder Secret:
#   The POLYMARKET_BUILDER_SECRET (used for HMAC signing) must NEVER be exposed
#   to the browser. It belongs in a server-side signing proxy only.
#   • For GitHub Pages (static): Deploy the signing proxy as a separate service
#     (Vercel Edge Function, Netlify Function, or a small Node/Express server).
#   • Set VITE_POLYMARKET_BUILDER_RELAY_SIGN_URL to your proxy's URL.
#   • Add POLYMARKET_BUILDER_SECRET as a secret on that server only.
#   • Reference implementation: https://github.com/Polymarket/magic-safe-builder-example
#
VITE_POLYMARKET_BUILDER_API_KEY=
VITE_POLYMARKET_BUILDER_PASSPHRASE=
# URL of your server-side signing proxy endpoint (e.g. https://your-api.example.com/api/polymarket/sign)
VITE_POLYMARKET_BUILDER_RELAY_SIGN_URL=

# ── PayPal ─────────────────────────────────────────────────────────────────────
# Create an app at https://developer.paypal.com → My Apps & Credentials
# Use "sb" for sandbox testing, or your live Client ID for production.
VITE_PAYPAL_CLIENT_ID=sb

# ── Coinbase Commerce ──────────────────────────────────────────────────────────
# 1. Create an account at https://commerce.coinbase.com
# 2. Create a "Checkout" (not a charge) in the Commerce dashboard
# 3. Copy the Checkout UUID here
VITE_COINBASE_CHECKOUT_ID=

# ── Payfast ────────────────────────────────────────────────────────────────────
# Register at https://www.payfast.co.za
#
# Sandbox / test credentials (safe to use in development and CI):
#   merchant_id : 10000100
#   merchant_key: 46f0cd694581a
#   endpoint    : https://sandbox.payfast.co.za/eng/process
#
# To test sandbox payments locally:
#   1. Set VITE_PAYFAST_SANDBOX=true (already the default below)
#   2. Use the sandbox buyer account: buyer@example.com / Test1234
#   3. All card details on https://developers.payfast.co.za/docs#testing
#
# For live payments, replace the values with your live merchant credentials
# and set VITE_PAYFAST_SANDBOX=false.
VITE_PAYFAST_MERCHANT_ID=10000100
VITE_PAYFAST_MERCHANT_KEY=46f0cd694581a
# Set to "false" to use the live Payfast endpoint
VITE_PAYFAST_SANDBOX=true
